# Copy to `.env` and fill in. Never commit real secrets.
SECRET_KEY=change-me-to-a-long-random-string
FLASK_DEBUG=false
HOST=0.0.0.0
PORT=5000
DB_PATH=loja.db
# Comma-separated allowlist of browser origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Token required to call destructive admin endpoints; empty disables them
ADMIN_TOKEN=
